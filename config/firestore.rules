rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // Helper function to check if this is a placeholder journal being claimed
    function isClaimingPlaceholder() {
      return resource.data.userId.matches('placeholder-.*') &&
             request.resource.data.userId == request.auth.uid;
    }
    
    // Journals - users can access their own entries, admin can access all
    match /journals/{journalId} {
      // Allow list (query) for authenticated users - filter in app code
      allow list: if request.auth != null;
      // Allow get if owner, admin, or placeholder
      allow get: if request.auth != null && 
                   (request.auth.uid == resource.data.userId || 
                    resource.data.userId.matches('placeholder-.*') ||
                    isAdmin());
      // Allow update if owner, admin, or claiming a placeholder
      allow update: if request.auth != null && 
                      (request.auth.uid == resource.data.userId || 
                       isClaimingPlaceholder() ||
                       isAdmin());
      // Allow delete if owner or admin
      allow delete: if request.auth != null && 
                      (request.auth.uid == resource.data.userId || isAdmin());
      // Allow create for owner or admin (admin can create journals for players)
      allow create: if request.auth != null && 
                      (request.auth.uid == request.resource.data.userId || isAdmin());
    }
    
    // Users - can read own profile, can write own profile on creation
    match /users/{userId} {
      allow read: if request.auth != null && 
                    (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Checklists - users can access their own, admin can access all
    match /checklists/{checklistId} {
      // Allow list (query) for authenticated users
      allow list: if request.auth != null;
      // Allow get if owner or admin
      allow get: if request.auth != null && 
                   (request.auth.uid == resource.data.userId || isAdmin());
      // Allow write if owner or admin
      allow update, delete: if request.auth != null && 
                              (request.auth.uid == resource.data.userId || isAdmin());
      // Allow create for authenticated users (as owner)
      allow create: if request.auth != null && 
                      request.auth.uid == request.resource.data.userId;
    }
    
    // Inventories - personal inventories for users, party inventories shared
    match /inventories/{inventoryId} {
      // Allow list for authenticated users
      allow list: if request.auth != null;
      // Allow get for authenticated users (filter access in app code)
      allow get: if request.auth != null;
      // Allow create/update/delete for authenticated users
      allow create, update, delete: if request.auth != null;
    }
    
    // Parties - party definitions
    match /parties/{partyId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }
  }
}
